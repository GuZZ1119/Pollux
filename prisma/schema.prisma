generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model GmailToken {
  userId       String   @id
  accessToken  String
  refreshToken String
  scope        String   @default("")
  expiresAt    BigInt
  email        String?
  updatedAt    DateTime @updatedAt
}

model StyleProfile {
  userId    String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model SendLog {
  id              String   @id @default(cuid())
  userId          String
  provider        String
  sourceMessageId String
  sourceThreadId  String?
  sourceSender    String?
  sourceSubject   String?
  candidateText   String?
  finalText       String
  wasEdited       Boolean  @default(false)
  styleSource     String?
  stylePersona    String?
  sendChannel     String
  success         Boolean
  error           String?
  sentAt          DateTime @default(now())

  @@index([userId])
  @@index([userId, sentAt])
}
