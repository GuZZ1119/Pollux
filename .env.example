# ============================================
# Auth0
# ============================================
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=          # openssl rand -hex 32
APP_BASE_URL=http://localhost:3000          # ngrok 时改为 https://xxx.ngrok-free.dev

# Auth0 Token Vault — Outlook / Microsoft connection
# The connection name configured in Auth0 Dashboard for Microsoft.
# Defaults to "windowslive" if not set.
# AUTH0_MS_CONNECTION_NAME=windowslive

# ============================================
# Google / Gmail OAuth
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# ============================================
# Slack OAuth
# ============================================
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=                       # 默认从 APP_BASE_URL 推导，一般不需要单独设置

# ============================================
# OpenAI
# ============================================
OPENAI_API_KEY=

# ============================================
# Inbox Configuration
# ============================================
# INBOX_MAX_RESULTS=30

# ============================================
# Database (Neon PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/pollux?sslmode=require
